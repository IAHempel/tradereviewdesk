{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "es2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@tradenoc/config/*": ["packages/config/src/*"],
      "@tradenoc/schemas/*": ["packages/schemas/src/*"],
      "@tradenoc/types/*": ["packages/types/src/*"],
      "@tradenoc/ui/*": ["packages/ui/src/*"],
      "@tradenoc/utils/*": ["packages/utils/src/*"]
    }
  }
}
